{
  "name": "akeyless-action",
  "version": "5.3.0",
  "type": "module",
  "description": "This action will login to AKeyless using JWT or IAM auth and then fetch secrets and/or provision AWS access via a dynamic producer.",
  "main": "dist/index.cjs",
  "scripts": {
    "restore": "npm install",
    "format": "prettier --write **/*.js",
    "lint": "eslint **/*.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "vitest run --reporter=verbose",
    "test:coverage-verbose": "vitest run --coverage --reporter=verbose",
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && ncc build src/index.cjs -o dist --license licenses.txt && node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type:'commonjs'}, null, 2))\"",
    "rebuild": "npm ci && npm run build",
    "package": "npm run format && npm run lint && npm run test && npm run build",
    "precommit": "npm run restore && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanceMcCarthy/akeyless-action.git"
  },
  "keywords": [],
  "author": "Lance McCarthy",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/LanceMcCarthy/akeyless-action/issues"
  },
  "homepage": "https://github.com/LanceMcCarthy/akeyless-action#readme",
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@aws-sdk/credential-providers": "^3.1015.0",
    "@aws-sdk/signature-v4": "^3.374.0",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.1",
    "akeyless": "^5.0.16",
    "eslint": "^9.39.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-i18n-text": "^1.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "fast-xml-parser": "^5.5.3",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  }
}
